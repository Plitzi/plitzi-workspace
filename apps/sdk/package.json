{
  "name": "@plitzi/plitzi-sdk",
  "version": "0.27.19",
  "homepage": "./",
  "license": "BSL-1.0",
  "files": [
    "dist"
  ],
  "main": "dist/plitzi-sdk.js",
  "exports": {
    ".": "./dist/plitzi-sdk.js",
    "./plitzi-sdk.css": "./dist/plitzi-sdk.css"
  },
  "repository": {
    "type": "https",
    "url": "https://github.com/plitzi/plitzi-workspace.git"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "type": "module",
  "dependencies": {
    "@apollo/client": "^4.1.4",
    "@auth0/auth0-react": "^2.13.0",
    "@dr.pogodin/react-helmet": "^3.0.6",
    "@plitzi/plitzi-ui": "^1.2.16",
    "@plitzi/sdk-auth": "workspace:*",
    "@plitzi/sdk-dev-tools": "workspace:*",
    "@plitzi/sdk-elements": "workspace:*",
    "@plitzi/sdk-event-bridge": "workspace:*",
    "@plitzi/sdk-interactions": "workspace:*",
    "@plitzi/sdk-navigation": "workspace:*",
    "@plitzi/sdk-plugins": "workspace:*",
    "@plitzi/sdk-schema": "workspace:*",
    "@plitzi/sdk-shared": "workspace:*",
    "@plitzi/sdk-state": "workspace:*",
    "@plitzi/sdk-style": "workspace:*",
    "@plitzi/sdk-variables": "workspace:*",
    "clsx": "^2.1.1",
    "graphql": "^16.12.0",
    "handlebars": "^4.7.8",
    "immer": "^11.1.3",
    "lodash-es": "^4.17.23",
    "react-router-dom": "^7.13.0",
    "twig": "^1.17.1",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-react": "^4.0.1"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@babel/compat-data": "^7.29.0",
    "@babel/core": "^7.29.0",
    "@babel/helper-builder-react-jsx-experimental": "^7.12.11",
    "@babel/helper-validator-identifier": "^7.28.5",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-transform-private-methods": "^7.28.6",
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/polyfill": "^7.12.1",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@storybook/addon-links": "^10.2.7",
    "@storybook/react": "^10.2.7",
    "@storybook/react-webpack5": "^10.2.7",
    "@storybook/testing-library": "^0.2.2",
    "@tailwindcss/postcss": "^4.1.18",
    "css-loader": "^7.1.3",
    "eslint": "^9.39.2",
    "flow-bin": "^0.299.0",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-refresh": "^0.18.0",
    "react-test-renderer": "^19.2.4",
    "rollup-plugin-visualizer": "^6.0.5",
    "sass": "^1.97.3",
    "sass-embedded": "^1.97.3",
    "storybook": "^10.2.7",
    "stylelint": "^17.1.1",
    "stylelint-order": "^7.0.1",
    "stylelint-scss": "^7.0.0",
    "typescript": "^5.9.3",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-ejs": "^1.7.0",
    "vite-plugin-mkcert": "^1.17.9"
  },
  "scripts": {
    "start": "vite dev --mode development",
    "test": "node --experimental-vm-modules ../../node_modules/.bin/jest",
    "test:coverage": "jest --coverage",
    "lint": "TIMING=1 eslint ./src",
    "lint-style": "stylelint \"**/*.scss\" --custom-syntax postcss-scss",
    "lint-style:fix": "stylelint \"**/*.scss\" --custom-syntax postcss-scss --fix",
    "typecheck": "tsc --noEmit",
    "build-assets:dev": "tsc --noEmit && vite build --mode development",
    "build-assets:dev-watch": "tsc --noEmit && vite build --mode development --watch",
    "build-assets:dev-gzip": "tsc --noEmit && ONLY_GZIP=1 vite build --mode development",
    "build-assets:dev-analyze": "tsc --noEmit && ONLY_ANALYZE=1 vite build --mode development",
    "build-assets:prod": "tsc --noEmit && vite build",
    "build-assets:prod-watch": "tsc --noEmit && vite build --watch",
    "build-assets:prod-gzip": "tsc --noEmit && ONLY_GZIP=1 vite build",
    "build-assets:prod-analyze": "tsc --noEmit && ONLY_ANALYZE=1 vite build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
