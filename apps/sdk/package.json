  "homepage": "./",
  "license": "AGPL-3.0",
  "files": [
    "dist"
  ],
  "main": "dist/plitzi-sdk.js",
  "module": "dist/plitzi-sdk.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/plitzi-sdk.js",
      "default": "./dist/plitzi-sdk.js"
    },
    "./plitzi-sdk.css": "./dist/plitzi-sdk.css",
    "./plitzi-sdk-devtools.css": "./dist/plitzi-sdk-devtools.css",
    "./plitzi-sdk-vendor.js": "./dist/plitzi-sdk-vendor.js",
    "./plitzi-sdk-dev-vendor.js": "./dist/plitzi-sdk-dev-vendor.js",
    "./plitzi-sdk-dev-vendor.js.map": "./dist/plitzi-sdk-dev-vendor.js.map"
  },
  "repository": {
    "type": "https",
    "url": "https://github.com/plitzi/plitzi-workspace.git"
  },
  "type": "module",
  "sideEffects": false,
  "dependencies": {
    "@apollo/client": "^4.2.6",
    "@auth0/auth0-react": "^2.21.0",
    "@dr.pogodin/react-helmet": "^3.2.2",
    "@fortawesome/fontawesome-free": "^7.3.0",
    "@plitzi/nexus": "workspace:*",
    "@plitzi/plitzi-ui": "^1.6.16",
    "@plitzi/sdk-auth": "workspace:*",
    "@plitzi/sdk-collections": "workspace:*",
    "@plitzi/sdk-dev-tools": "workspace:*",
    "@plitzi/sdk-elements": "workspace:*",
    "@plitzi/sdk-event-bridge": "workspace:*",
    "@plitzi/sdk-interactions": "workspace:*",
    "@plitzi/sdk-navigation": "workspace:*",
    "@plitzi/sdk-plugins": "workspace:*",
    "@plitzi/sdk-schema": "workspace:*",
    "@plitzi/sdk-shared": "workspace:*",
    "@plitzi/sdk-style": "workspace:*",
    "@plitzi/sdk-variables": "workspace:*",
    "clsx": "^2.1.1",
    "graphql": "^17.0.2",
    "immer": "^11.1.11",
    "react-router-dom": "^7.18.1",
    "vite": "^8.1.4",
    "vite-plugin-dts": "^5.0.3",
    "vite-plugin-react": "^4.0.1"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@babel/compat-data": "^8.0.0",
    "@babel/core": "^8.0.1",
    "@babel/helper-builder-react-jsx-experimental": "^7.12.11",
    "@babel/helper-validator-identifier": "^8.0.4",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-transform-private-methods": "^8.0.1",
    "@babel/plugin-transform-react-jsx": "^8.0.1",
    "@babel/plugin-transform-runtime": "^8.0.1",
    "@babel/polyfill": "^7.12.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@storybook/addon-links": "^10.5.0",
    "@storybook/react": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@storybook/react-webpack5": "^10.5.0",
    "@storybook/testing-library": "^0.2.2",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/ejs": "^3.1.5",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "flow-bin": "^0.322.0",
    "mini-css-extract-plugin": "^2.10.2",
    "postcss": "^8.5.17",
    "postcss-loader": "^8.2.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.9.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-refresh": "^0.18.0",
    "react-test-renderer": "^19.2.7",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.101.0",
    "sass-embedded": "^1.100.0",
    "storybook": "^10.5.0",
    "stylelint": "^17.14.0",
    "stylelint-order": "^8.1.1",
    "stylelint-scss": "^7.2.0",
    "terser": "^5.49.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-ejs": "^2.0.0",
    "vite-plugin-mkcert": "^2.1.0",
    "vitest": "^4.1.10"
  },
  "scripts": {
    "start": "vite dev --mode development",
    "test": "vitest run",
    "test:coverage": "",
    "lint": "TIMING=1 eslint ./src",
    "lint-style": "stylelint \"**/*.scss\" --custom-syntax postcss-scss",
    "lint-style:fix": "stylelint \"**/*.scss\" --custom-syntax postcss-scss --fix",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "build:dev": "tsc -p tsconfig.app.json --noEmit && vite build --mode development",
    "build:dev-watch": "tsc -p tsconfig.app.json --noEmit && vite build --mode development --watch",
    "build:dev-gzip": "tsc -p tsconfig.app.json --noEmit && ONLY_GZIP=1 vite build --mode development",
    "build:dev-analyze": "tsc -p tsconfig.app.json --noEmit && ONLY_ANALYZE=1 vite build --mode development",
    "build:prod": "tsc -p tsconfig.app.json --noEmit && vite build",
    "build:prod-watch": "tsc -p tsconfig.app.json --noEmit && vite build --watch",
    "build:prod-gzip": "tsc -p tsconfig.app.json --noEmit && ONLY_GZIP=1 vite build",
    "build:prod-analyze": "tsc -p tsconfig.app.json --noEmit && ONLY_ANALYZE=1 vite build",
    "build-vendor:dev": "vite build --config vite.vendor.config.ts --mode development",
    "build-vendor:prod": "vite build --config vite.vendor.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
