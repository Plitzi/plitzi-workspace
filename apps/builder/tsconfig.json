{
  "extends": "../../packages/sdk-shared/tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",
    "paths": {
      "@pmodules/*": ["./src/modules/*"],
      "@pcomponents/*": ["./src/components/*"]
    }
  },
  "include": [
    "../sdk-shared/vite.config.ts",
    "../sdk-shared/package.json",
    "**/*.json",
    "src/*.ts",
    "src/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.ts",
    "setupTests.ts"
  ]
}
