{
  "extends": "@plitzi/sdk-shared/tsconfig.app.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "strict": true,
    "outDir": "./dist"
  },
  "paths": {
    "@pmodules/*": ["./src/modules/*"],
    "@pcomponents/*": ["./src/components/*"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/*.ts", "src/*.tsx", "src/**/*.json"]
}
