  "scripts": {
    "start": "vite dev --mode development",
    "test": "vitest run",
    "test:coverage": "",
    "lint": "TIMING=1 eslint ./src",
    "lint-style": "stylelint \"**/*.scss\" --custom-syntax postcss-scss",
    "lint-style:fix": "stylelint \"**/*.scss\" --custom-syntax postcss-scss --fix",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "build-assets:dev": "tsc -p tsconfig.app.json --noEmit && vite build --mode development",
    "build-assets:dev-watch": "tsc -p tsconfig.app.json --noEmit && vite build --mode development --watch",
    "build-assets:dev-gzip": "tsc -p tsconfig.app.json --noEmit && ONLY_GZIP=1 vite build --mode development",
    "build-assets:dev-analyze": "tsc -p tsconfig.app.json --noEmit && ONLY_ANALYZE=1 vite build --mode development",
    "build-assets:prod": "tsc -p tsconfig.app.json --noEmit && vite build",
    "build-assets:prod-watch": "tsc -p tsconfig.app.json --noEmit && vite build --watch",
    "build-assets:prod-gzip": "tsc -p tsconfig.app.json --noEmit && ONLY_GZIP=1 vite build",
    "build-assets:prod-analyze": "tsc -p tsconfig.app.json --noEmit && ONLY_ANALYZE=1 vite build"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
