    "dist"
  ],
  "repository": {
    "type": "https",
    "url": "https://github.com/plitzi/plitzi-workspace.git"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "type": "module",
  "main": "dist/plitzi-builder.js",
  "dependencies": {
    "@apollo/client": "^4.0.11",
    "@plitzi/plitzi-sdk": "workspace:*",
    "@plitzi/plitzi-ui": "^1.1.14",
    "@plitzi/sdk-auth": "workspace:*",
    "@plitzi/sdk-event-bridge": "workspace:*",
    "@plitzi/sdk-interactions": "workspace:*",
    "@plitzi/sdk-navigation": "workspace:*",
    "@plitzi/sdk-plugins": "workspace:*",
    "@plitzi/sdk-schema": "workspace:*",
    "@plitzi/sdk-shared": "workspace:*",
    "@plitzi/sdk-state": "workspace:*",
    "@plitzi/sdk-style": "workspace:*",
    "@plitzi/sdk-variables": "workspace:*",
    "@xyflow/react": "^12.10.0",
    "apollo-upload-client": "^19.0.0",
    "clsx": "^2.1.1",
    "graphql": "^16.12.0",
    "graphql-ws": "^6.0.6",
    "immer": "^11.1.3",
    "jszip": "^3.10.1",
    "lodash-es": "^4.17.22",
    "react-hook-form": "^7.69.0",
    "react-router-dom": "^7.11.0",
    "swr": "^2.3.8",
    "twig": "^1.17.1",
    "uuid": "^13.0.0",
    "zod": "^4.2.1"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@babel/compat-data": "^7.28.5",
    "@babel/core": "^7.28.5",
    "@babel/helper-builder-react-jsx-experimental": "^7.12.11",
    "@babel/helper-validator-identifier": "^7.28.5",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-transform-private-methods": "^7.27.1",
    "@babel/plugin-transform-runtime": "^7.28.5",
    "@babel/polyfill": "^7.12.1",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/lodash-es": "^4.17.12",
    "babel-loader": "^10.0.0",
    "css-loader": "^7.1.2",
    "cypress": "15.8.1",
    "eslint": "^9.39.2",
    "file-loader": "^6.2.0",
    "flow-bin": "^0.295.0",
    "jest": "^30.2.0",
    "mini-css-extract-plugin": "^2.9.4",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.7.4",
    "prop-types": "^15.8.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-refresh": "^0.18.0",
    "react-test-renderer": "^19.2.3",
    "sass": "^1.97.1",
    "sass-embedded": "^1.97.1",
    "sass-loader": "^16.0.6",
    "stylelint": "^16.26.1",
    "stylelint-order": "^7.0.1",
    "stylelint-scss": "^6.14.0",
    "thread-loader": "^4.0.4",
    "typescript": "^5.9.3",
    "url-loader": "^4.1.1",
    "vite": "^7.3.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-ejs": "^1.7.0",
    "vite-plugin-mkcert": "^1.17.9",
    "vite-plugin-react": "^4.0.1"
  },
  "scripts": {
    "start": "vite dev --mode development",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "TIMING=1 eslint ./src",
    "lint-style": "stylelint \"**/*.scss\" --custom-syntax postcss-scss",
    "lint-style:fix": "stylelint \"**/*.scss\" --custom-syntax postcss-scss --fix",
    "typecheck": "tsc --noEmit",
    "build-assets:dev": "tsc --noEmit && vite build --mode development",
    "build-assets:dev-watch": "tsc --noEmit && vite build --mode development --watch",
    "build-assets:dev-gzip": "tsc --noEmit && ONLY_GZIP=1 vite build --mode development",
    "build-assets:dev-analyze": "tsc --noEmit && ONLY_ANALYZE=1 vite build --mode development",
    "build-assets:prod": "tsc --noEmit && vite build",
    "build-assets:prod-watch": "tsc --noEmit && vite build --watch",
    "build-assets:prod-gzip": "tsc --noEmit && ONLY_GZIP=1 vite build",
    "build-assets:prod-analyze": "tsc --noEmit && ONLY_ANALYZE=1 vite build"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
