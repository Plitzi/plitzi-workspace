{
  "name": "@plitzi/plitzi-workspace",
  "private": true,
  "scripts": {
    "start": "turbo start --parallel",
    "start:debug": "turbo start:debug --parallel",
    "test": "turbo test --parallel",
    "test:coverage": "turbo test:coverage --parallel",
    "lint": "turbo lint --parallel",
    "lint-style": "turbo lint-style --parallel",
    "lint-style:fix": "turbo lint-style:fix --parallel",
    "build-assets:dev": "turbo build-assets:dev",
    "build-assets:dev-watch": "turbo build-assets:dev-watch --parallel",
    "build-assets:dev-measure": "turbo build-assets:dev-measure --parallel",
    "build-assets:dev-gzip": "turbo build-assets:dev-gzip",
    "build-assets:dev-analyze": "turbo build-assets:dev-analyze --parallel",
    "build-assets:prod": "turbo build-assets:prod",
    "build-assets:prod-watch": "turbo build-assets:prod-watch --parallel",
    "build-assets:prod-measure": "turbo build-assets:prod-measure --parallel",
    "build-assets:prod-gzip": "turbo build-assets:prod-gzip",
    "build-assets:prod-analyze": "turbo build-assets:prod-analyze --parallel",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "changeset": "changeset"
  },
  "dependencies": {
    "@plitzi/plitzi-ui-components": "0.13.12",
    "@plitzi/sdk-shared": "*"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "turbo": "^2.0.9"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.2.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
