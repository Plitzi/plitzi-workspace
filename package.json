{
  "name": "@plitzi/plitzi-workspace",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ]
  },
  "scripts": {
    "start": "turbo start --parallel",
    "start:debug": "turbo start:debug --parallel",
    "test": "turbo test --parallel",
    "test:coverage": "turbo test:coverage --parallel",
    "lint": "turbo lint --parallel",
    "lint-style": "turbo lint-style --parallel",
    "lint-style:fix": "turbo lint-style:fix --parallel",
    "build-assets:dev": "webpack --mode development",
    "build-assets:dev-watch": "webpack --mode development --env watch",
    "build-assets:dev-measure": "webpack --mode development --env measure",
    "build-assets:dev-gzip": "webpack --mode development --env onlyGzip",
    "build-assets:dev-analyze": "webpack --mode development --env onlyAnalyze",
    "build-assets:prod": "webpack --mode production",
    "build-assets:prod-watch": "webpack --mode production --env watch",
    "build-assets:prod-measure": "webpack --mode production --env measure",
    "build-assets:prod-gzip": "webpack --mode production --env onlyGzip",
    "build-assets:prod-analyze": "webpack --mode production --env onlyAnalyze",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "turbo": "^1.12.3"
  }
}
