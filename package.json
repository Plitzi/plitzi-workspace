{
  "name": "@plitzi/plitzi-workspace",
  "private": true,
  "scripts": {
    "start": "turbo start --parallel",
    "start:debug": "turbo start:debug --parallel --concurrency=20",
    "test": "turbo test --parallel",
    "test:coverage": "turbo test:coverage --parallel --concurrency=20",
    "lint": "turbo lint --parallel",
    "lint-style": "turbo lint-style --parallel",
    "lint-style:fix": "turbo lint-style:fix --parallel --concurrency=20",
    "typecheck": "tsc --noEmit",
    "build-assets:dev": "turbo build-assets:dev",
    "build-assets:dev-watch": "turbo build-assets:dev-watch --parallel --concurrency=20",
    "build-assets:dev-measure": "turbo build-assets:dev-measure --parallel --concurrency=20",
    "build-assets:dev-gzip": "turbo build-assets:dev-gzip",
    "build-assets:dev-analyze": "turbo build-assets:dev-analyze --parallel --concurrency=20",
    "build-assets:prod": "turbo build-assets:prod",
    "build-assets:prod-watch": "turbo build-assets:prod-watch --parallel --concurrency=20",
    "build-assets:prod-measure": "turbo build-assets:prod-measure --parallel --concurrency=20",
    "build-assets:prod-gzip": "turbo build-assets:prod-gzip",
    "build-assets:prod-analyze": "turbo build-assets:prod-analyze --parallel --concurrency=20",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "changeset": "changeset",
    "release": "yarn workspaces foreach -A npm publish --tolerate-republish --registry=https://npm.pkg.github.com"
  },
  "dependencies": {
    "@plitzi/plitzi-ui": "^1.0.0",
    "@plitzi/plitzi-ui-components": "0.14.14",
    "@plitzi/sdk-shared": "workspace:*",
    "react-router": "^7.8.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@types/react": "^19.1.12",
    "eslint": "^9.35.0",
    "jest": "^30.1.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "turbo": "^2.5.6"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.2.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
