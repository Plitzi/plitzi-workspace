{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "start": {
      "dependsOn": ["^start"],
      "cache": false,
      "persistent": true
    },
    "start:debug": {
      "dependsOn": ["^start:debug"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^test"],
      "cache": false
    },
    "test:coverage": {
      "dependsOn": ["^test:coverage"],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"],
      "cache": false
    },
    "lint-style": {
      "dependsOn": ["^lint-style"],
      "cache": false
    },
    "lint-style:fix": {
      "dependsOn": ["^lint-style:fix"],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "cache": false
    },
    "build:dev": {
      "dependsOn": ["^build:dev"],
      "cache": false,
      "outputs": ["dist/**"]
    },
    "build:dev-watch": {
      "cache": false,
      "persistent": true,
      "outputs": ["dist/**"]
    },
    "build:dev-measure": {
      "dependsOn": ["^build:dev-measure"],
      "cache": false,
      "outputs": ["dist/**"]
    },
    "build:dev-gzip": {
      "dependsOn": ["^build:dev-gzip"],
      "cache": false,
      "outputs": ["dist/**"]
    },
    "build:dev-analyze": {
      "dependsOn": ["^build:dev-analyze"],
      "cache": false,
      "outputs": ["dist/**"]
    },
    "build:prod": {
      "dependsOn": ["^build:prod"],
      "cache": false,
      "outputs": ["dist/**"]
    },
    "build:prod-watch": {
      "dependsOn": [],
      "cache": false,
      "persistent": true,
      "outputs": ["dist/**"]
    },
    "build:prod-measure": {
      "dependsOn": ["^build:prod-measure"],
      "cache": false,
      "outputs": ["dist/**"]
    },
    "build:prod-gzip": {
      "dependsOn": ["^build:prod-gzip"],
      "cache": false,
      "outputs": ["dist/**"]
    },
    "build:prod-analyze": {
      "dependsOn": ["^build:prod-analyze"],
      "cache": false,
      "outputs": ["dist/**"]
    }
  }
}
