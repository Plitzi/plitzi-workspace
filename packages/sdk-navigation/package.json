{
  "name": "@plitzi/sdk-navigation",
  "version": "0.23.24",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./NavigationHelper": {
      "types": "./dist/NavigationHelper.d.ts",
      "import": "./dist/NavigationHelper.mjs",
      "require": "./dist/NavigationHelper.cjs"
    },
    "./NavigationContext": {
      "types": "./dist/NavigationContext.d.ts",
      "import": "./dist/NavigationContext.mjs",
      "require": "./dist/NavigationContext.cjs"
    },
    "./useNavigation": {
      "types": "./dist/hooks/useNavigation.d.ts",
      "import": "./dist/hooks/useNavigation.mjs",
      "require": "./dist/hooks/useNavigation.cjs"
    }
  },
  "scripts": {
    "lint": "eslint ./src",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "build-assets:dev": "tsc -p ./tsconfig.app.json && vite build --mode development --minify false",
    "build-assets:dev-watch": "tsc -p ./tsconfig.app.json && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc -p ./tsconfig.app.json && vite build"
  },
  "type": "module",
  "devDependencies": {
    "eslint": "^9.19.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  },
  "dependencies": {
    "@plitzi/sdk-shared": "workspace:*",
    "lodash": "^4.17.21",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-router": "^7.1.5",
    "react-router-dom": "^7.1.5"
  }
}
