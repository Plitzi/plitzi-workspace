{
  "name": "@plitzi/sdk-navigation",
  "version": "0.24.9",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/src/index.mjs",
      "types": "./dist/src/index.d.ts"
    },
    "./NavigationContext": {
      "import": "./dist/src/NavigationContext.mjs",
      "types": "./dist/src/NavigationContext.d.ts"
    },
    "./NavigationHelper": {
      "import": "./dist/src/NavigationHelper.mjs",
      "types": "./dist/src/NavigationHelper.d.ts"
    },
    "./hooks/useNavigation": {
      "import": "./dist/src/hooks/useNavigation.mjs",
      "types": "./dist/src/hooks/useNavigation.d.ts"
    },
    "./index": {
      "import": "./dist/src/index.mjs",
      "types": "./dist/src/index.d.ts"
    }
  },
  "scripts": {
    "lint": "eslint ./src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "build-assets:dev": "tsc && vite build --mode development --minify false && node ../sdk-shared/scripts/generate-exports.mjs",
    "build-assets:dev-watch": "tsc && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc && vite build && node ../sdk-shared/scripts/generate-exports.mjs"
  },
  "type": "module",
  "devDependencies": {
    "eslint": "^9.37.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.9",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "dependencies": {
    "@plitzi/sdk-shared": "workspace:*",
    "lodash": "^4.17.21",
    "react-router": "^7.9.4",
    "react-router-dom": "^7.9.4"
  }
}
