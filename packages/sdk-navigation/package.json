{
  "name": "@plitzi/sdk-navigation",
  "version": "0.24.2",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es",
      "require": "./dist/index.cjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*",
      "require": "./dist/*"
    }
  },
  "scripts": {
    "lint": "eslint ./src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "build-assets:dev": "tsc && vite build --mode development --minify false",
    "build-assets:dev-watch": "tsc && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc && vite build"
  },
  "type": "module",
  "devDependencies": {
    "eslint": "^9.35.0",
    "vite": "^7.1.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@plitzi/sdk-shared": "workspace:*",
    "lodash": "^4.17.21",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-router": "^7.8.2",
    "react-router-dom": "^7.8.2"
  }
}
