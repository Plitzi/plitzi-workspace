{
  "name": "@plitzi/sdk-navigation",
  "version": "0.23.24",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es",
      "require": "./dist/index.cjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*",
      "require": "./dist/*"
    }
  },
  "scripts": {
    "lint": "eslint ./src",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "build-assets:dev": "tsc -p ./tsconfig.app.json && vite build --mode development --minify false",
    "build-assets:dev-watch": "tsc -p ./tsconfig.app.json && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc -p ./tsconfig.app.json && vite build"
  },
  "type": "module",
  "devDependencies": {
    "eslint": "^9.27.0",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  },
  "dependencies": {
    "@plitzi/sdk-shared": "workspace:*",
    "lodash": "^4.17.21",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router": "^7.6.0",
    "react-router-dom": "^7.6.0"
  }
}
