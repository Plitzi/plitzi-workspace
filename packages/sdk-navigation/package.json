{
  "name": "@plitzi/sdk-navigation",
  "version": "0.30.19",
  "license": "AGPL-3.0",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./NavigationContext": {
      "types": "./dist/NavigationContext.d.ts",
      "import": "./dist/NavigationContext.mjs"
    },
    "./NavigationHelper": {
      "types": "./dist/NavigationHelper.d.ts",
      "import": "./dist/NavigationHelper.mjs"
    },
    "./hooks/useNavigation": {
      "types": "./dist/hooks/useNavigation.d.ts",
      "import": "./dist/hooks/useNavigation.mjs"
    },
    "./index": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "lint": "eslint ./src",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "build:dev": "vite build --mode development --minify false && node ../sdk-shared/scripts/generate-exports.mjs",
    "build:dev-watch": "vite build --mode development --watch --minify false",
    "build:prod": "vite build && node ../sdk-shared/scripts/generate-exports.mjs"
  },
  "type": "module",
  "sideEffects": false,
  "devDependencies": {
    "eslint": "^9.39.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "dependencies": {
    "@plitzi/plitzi-ui": "^1.6.7",
    "@plitzi/sdk-shared": "workspace:*",
    "react-router": "^7.15.0",
    "react-router-dom": "^7.15.0"
  }
}
