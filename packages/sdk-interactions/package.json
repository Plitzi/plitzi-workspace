{
  "name": "@plitzi/sdk-interactions",
  "version": "0.28.14",
  "license": "GPLv3",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.mjs"
    },
    "./InteractionsContext": {
      "types": "./dist/src/InteractionsContext.d.ts",
      "import": "./dist/src/InteractionsContext.mjs"
    },
    "./InteractionsContextProvider": {
      "types": "./dist/src/InteractionsContextProvider.d.ts",
      "import": "./dist/src/InteractionsContextProvider.mjs"
    },
    "./InteractionsHelper": {
      "types": "./dist/src/InteractionsHelper.d.ts",
      "import": "./dist/src/InteractionsHelper.mjs"
    },
    "./InteractionsManager": {
      "types": "./dist/src/InteractionsManager.d.ts",
      "import": "./dist/src/InteractionsManager.mjs"
    },
    "./hooks/useInteractions": {
      "types": "./dist/src/hooks/useInteractions.d.ts",
      "import": "./dist/src/hooks/useInteractions.mjs"
    },
    "./index": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.mjs"
    },
    "./sources": {
      "types": "./dist/src/sources/index.d.ts",
      "import": "./dist/src/sources/index.mjs"
    },
    "./sources/AuthSource": {
      "types": "./dist/src/sources/AuthSource/index.d.ts",
      "import": "./dist/src/sources/AuthSource/index.mjs"
    },
    "./sources/AuthSource/AuthInteractions": {
      "types": "./dist/src/sources/AuthSource/AuthInteractions.d.ts",
      "import": "./dist/src/sources/AuthSource/AuthInteractions.mjs"
    },
    "./sources/AuthSource/index": {
      "types": "./dist/src/sources/AuthSource/index.d.ts",
      "import": "./dist/src/sources/AuthSource/index.mjs"
    },
    "./sources/index": {
      "types": "./dist/src/sources/index.d.ts",
      "import": "./dist/src/sources/index.mjs"
    },
    "./utility": {
      "types": "./dist/src/utility/index.d.ts",
      "import": "./dist/src/utility/index.mjs"
    },
    "./utility/delayTime": {
      "types": "./dist/src/utility/delayTime.d.ts",
      "import": "./dist/src/utility/delayTime.mjs"
    },
    "./utility/index": {
      "types": "./dist/src/utility/index.d.ts",
      "import": "./dist/src/utility/index.mjs"
    },
    "./utility/twigTemplate": {
      "types": "./dist/src/utility/twigTemplate.d.ts",
      "import": "./dist/src/utility/twigTemplate.mjs"
    },
    "./utility/webHook": {
      "types": "./dist/src/utility/webHook.d.ts",
      "import": "./dist/src/utility/webHook.mjs"
    }
  },
  "scripts": {
    "lint": "eslint ./src",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "build-assets:dev": "tsc -p tsconfig.app.json && vite build --mode development --minify false && node ../sdk-shared/scripts/generate-exports.mjs",
    "build-assets:dev-watch": "tsc -p tsconfig.app.json && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc -p tsconfig.app.json && vite build && node ../sdk-shared/scripts/generate-exports.mjs"
  },
  "type": "module",
  "sideEffects": false,
  "devDependencies": {
    "eslint": "^9.39.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "@plitzi/plitzi-ui": "^1.5.17",
    "@plitzi/sdk-auth": "workspace:*",
    "@plitzi/sdk-dev-tools": "workspace:*",
    "@plitzi/sdk-event-bridge": "workspace:*",
    "@plitzi/sdk-shared": "workspace:*"
  }
}
