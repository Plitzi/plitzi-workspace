{
  "name": "@plitzi/sdk-interactions",
  "version": "0.23.24",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es",
      "require": "./dist/index.cjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*",
      "require": "./dist/*"
    }
  },
  "scripts": {
    "lint": "eslint ./src",
    "typecheck": "tsc --noEmit",
    "build-assets:dev": "tsc && vite build --mode development --minify false",
    "build-assets:dev-watch": "tsc && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc && vite build"
  },
  "type": "module",
  "devDependencies": {
    "eslint": "^9.27.0",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@plitzi/plitzi-ui": "^0.2.0",
    "@plitzi/sdk-auth": "workspace:*",
    "@plitzi/sdk-dev-tools": "workspace:*",
    "@plitzi/sdk-event-bridge": "workspace:*",
    "@plitzi/sdk-shared": "workspace:*",
    "lodash": "^4.17.21"
  }
}
