{
  "name": "@plitzi/sdk-style",
  "version": "0.23.24",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es",
      "require": "./dist/index.cjs"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*",
      "require": "./dist/components/*"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*",
      "require": "./dist/*"
    }
  },
  "type": "module",
  "scripts": {
    "lint": "eslint ./src",
    "typecheck": "tsc --noEmit",
    "build-assets:dev": "tsc -p ./tsconfig.app.json && vite build --mode development --minify false",
    "build-assets:dev-watch": "tsc -p ./tsconfig.app.json && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc -p ./tsconfig.app.json && vite build"
  },
  "dependencies": {
    "@plitzi/plitzi-ui": "^0.2.0",
    "@plitzi/sdk-plugins": "workspace:*",
    "@plitzi/sdk-shared": "workspace:*",
    "classnames": "^2.5.1",
    "immer": "^10.1.1",
    "lodash": "^4.17.21",
    "prop-types": "^15.8.1",
    "zod": "^3.25.21"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.17",
    "eslint": "^9.27.0",
    "vite": "^6.3.5"
  }
}
