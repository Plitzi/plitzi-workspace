{
  "name": "@plitzi/sdk-style",
  "version": "0.23.24",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./StyleContext": {
      "types": "./dist/StyleContext.d.ts",
      "import": "./dist/StyleContext.mjs",
      "require": "./dist/StyleContext.cjs"
    },
    "./StyleHelper": {
      "types": "./dist/StyleHelper.d.ts",
      "import": "./dist/StyleHelper.mjs",
      "require": "./dist/StyleHelper.cjs"
    },
    "./StyleMap": {
      "types": "./dist/StyleMap.d.ts",
      "import": "./dist/StyleMap.mjs",
      "require": "./dist/StyleMap.cjs"
    },
    "./StyleConstants": {
      "types": "./dist/StyleConstants.d.ts",
      "import": "./dist/StyleConstants.mjs",
      "require": "./dist/StyleConstants.cjs"
    }
  },
  "type": "module",
  "scripts": {
    "lint": "eslint ./src",
    "build-assets:dev": "tsc -p ./tsconfig.app.json && vite build --mode development --minify false",
