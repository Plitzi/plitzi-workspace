{
  "name": "@plitzi/sdk-auth",
  "version": "0.26.2",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.mjs"
    },
    "./UserBaseContextProvider": {
      "types": "./dist/src/UserBaseContextProvider.d.ts",
      "import": "./dist/src/UserBaseContextProvider.mjs"
    },
    "./UserContext": {
      "types": "./dist/src/UserContext.d.ts",
      "import": "./dist/src/UserContext.mjs"
    },
    "./hocs/withUserProvider": {
      "types": "./dist/src/hocs/withUserProvider.d.ts",
      "import": "./dist/src/hocs/withUserProvider.mjs"
    },
    "./hooks/useAuth": {
      "types": "./dist/src/hooks/useAuth/index.d.ts",
      "import": "./dist/src/hooks/useAuth/index.mjs"
    },
    "./hooks/useAuth/index": {
      "types": "./dist/src/hooks/useAuth/index.d.ts",
      "import": "./dist/src/hooks/useAuth/index.mjs"
    },
    "./hooks/useAuth/managers/BasicProvider": {
      "types": "./dist/src/hooks/useAuth/managers/BasicProvider.d.ts",
      "import": "./dist/src/hooks/useAuth/managers/BasicProvider.mjs"
    },
    "./hooks/useAuth/useAuth": {
      "types": "./dist/src/hooks/useAuth/useAuth.d.ts",
      "import": "./dist/src/hooks/useAuth/useAuth.mjs"
    },
    "./index": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.mjs"
    }
  },
  "type": "module",
  "scripts": {
    "lint": "eslint ./src",
    "typecheck": "tsc --noEmit",
    "build-assets:dev": "tsc && vite build --mode development --minify false && node ../sdk-shared/scripts/generate-exports.mjs",
    "build-assets:dev-watch": "tsc && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc && vite build && node ../sdk-shared/scripts/generate-exports.mjs"
  },
  "dependencies": {
    "@plitzi/plitzi-ui": "^1.1.6",
    "@plitzi/sdk-navigation": "workspace:*",
    "@plitzi/sdk-schema": "workspace:*",
    "@plitzi/sdk-shared": "workspace:*",
    "lodash-es": "^4.17.21",
    "moment": "^2.30.1"
  },
  "devDependencies": {
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  }
}
