{
  "name": "@plitzi/sdk-auth",
  "version": "0.27.23",
  "license": "BSL-1.0",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.mjs"
    },
    "./AuthContext": {
      "types": "./dist/src/AuthContext.d.ts",
      "import": "./dist/src/AuthContext.mjs"
    },
    "./AuthContextProvider": {
      "types": "./dist/src/AuthContextProvider.d.ts",
      "import": "./dist/src/AuthContextProvider.mjs"
    },
    "./AuthManager": {
      "types": "./dist/src/AuthManager.d.ts",
      "import": "./dist/src/AuthManager.mjs"
    },
    "./AuthProvider": {
      "types": "./dist/src/AuthProvider.d.ts",
      "import": "./dist/src/AuthProvider.mjs"
    },
    "./hooks/useAuth": {
      "types": "./dist/src/hooks/useAuth/index.d.ts",
      "import": "./dist/src/hooks/useAuth/index.mjs"
    },
    "./hooks/useAuth/index": {
      "types": "./dist/src/hooks/useAuth/index.d.ts",
      "import": "./dist/src/hooks/useAuth/index.mjs"
    },
    "./hooks/useAuth/useAuth": {
      "types": "./dist/src/hooks/useAuth/useAuth.d.ts",
      "import": "./dist/src/hooks/useAuth/useAuth.mjs"
    },
    "./index": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.mjs"
    },
    "./providers/Auth0Provider": {
      "types": "./dist/src/providers/Auth0Provider.d.ts",
      "import": "./dist/src/providers/Auth0Provider.mjs"
    },
    "./providers/BasicAuthProvider": {
      "types": "./dist/src/providers/BasicAuthProvider.d.ts",
      "import": "./dist/src/providers/BasicAuthProvider.mjs"
    }
  },
  "type": "module",
  "scripts": {
    "lint": "eslint ./src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "build-assets:dev": "tsc && vite build --mode development --minify false && node ../sdk-shared/scripts/generate-exports.mjs",
    "build-assets:dev-watch": "tsc && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc && vite build && node ../sdk-shared/scripts/generate-exports.mjs"
  },
  "dependencies": {
    "@plitzi/plitzi-ui": "^1.2.18",
    "@plitzi/sdk-navigation": "workspace:*",
    "@plitzi/sdk-schema": "workspace:*",
    "@plitzi/sdk-shared": "workspace:*",
    "lodash-es": "^4.17.23"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
