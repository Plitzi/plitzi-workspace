{
  "name": "@plitzi/sdk-auth",
  "version": "0.23.24",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es",
      "require": "./dist/index.cjs"
    },
    "./UserContext": {
      "types": "./dist/UserContext.d.ts",
      "import": "./dist/UserContext.es",
      "require": "./dist/UserContext.cjs"
    },
    "./UserBaseContextProvider": {
      "types": "./dist/UserBaseContextProvider.d.ts",
      "import": "./dist/UserBaseContextProvider.es",
      "require": "./dist/UserBaseContextProvider.cjs"
    }
  },
  "type": "module",
  "scripts": {
    "lint": "eslint ./src",
    "build-assets:dev": "tsc -p ./tsconfig.app.json && vite build --mode development --minify false",
    "build-assets:dev-watch": "tsc -p ./tsconfig.app.json && vite build --mode development --watch --minify false",
