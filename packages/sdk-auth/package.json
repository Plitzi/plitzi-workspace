{
  "name": "@plitzi/sdk-auth",
  "version": "0.32.7",
  "license": "AGPL-3.0",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./AuthContext": {
      "types": "./dist/AuthContext.d.ts",
      "import": "./dist/AuthContext.mjs"
    },
    "./AuthContextProvider": {
      "types": "./dist/AuthContextProvider.d.ts",
      "import": "./dist/AuthContextProvider.mjs"
    },
    "./AuthManager": {
      "import": "./dist/AuthManager.mjs"
    },
    "./AuthProvider": {
      "types": "./dist/AuthProvider.d.ts",
      "import": "./dist/AuthProvider.mjs"
    },
    "./hooks/useAuth": {
      "types": "./dist/hooks/useAuth/index.d.ts",
      "import": "./dist/hooks/useAuth/index.mjs"
    },
    "./hooks/useAuth/index": {
      "types": "./dist/hooks/useAuth/index.d.ts",
      "import": "./dist/hooks/useAuth/index.mjs"
    },
    "./hooks/useAuth/useAuth": {
      "types": "./dist/hooks/useAuth/useAuth.d.ts",
      "import": "./dist/hooks/useAuth/useAuth.mjs"
    },
    "./index": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./providers/Auth0Provider": {
      "types": "./dist/providers/Auth0Provider.d.ts",
      "import": "./dist/providers/Auth0Provider.mjs"
    },
    "./providers/BasicAuthProvider": {
      "types": "./dist/providers/BasicAuthProvider.d.ts",
      "import": "./dist/providers/BasicAuthProvider.mjs"
    }
  },
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "lint": "eslint ./src",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "build:dev": "vite build --mode development --minify false && node ../sdk-shared/scripts/generate-exports.mjs",
    "build:dev-watch": "vite build --mode development --watch --minify false",
    "build:prod": "vite build && node ../sdk-shared/scripts/generate-exports.mjs"
  },
  "dependencies": {
    "@plitzi/plitzi-ui": "^1.6.17",
    "@plitzi/sdk-navigation": "workspace:*",
    "@plitzi/sdk-schema": "workspace:*",
    "@plitzi/sdk-shared": "workspace:*"
  },
  "devDependencies": {
    "eslint": "^9.39.5",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
