  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./VariablesContext": {
      "types": "./dist/src/VariablesContext.d.ts",
      "import": "./dist/VariablesContext.mjs",
      "require": "./dist/VariablesContext.cjs"
    },
