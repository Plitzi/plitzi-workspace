{
  "name": "@plitzi/sdk-variables",
  "version": "0.27.0",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.mjs"
    },
    "./VariablesContext": {
      "types": "./dist/src/VariablesContext.d.ts",
      "import": "./dist/src/VariablesContext.mjs"
    },
    "./VariablesHelper": {
      "types": "./dist/src/VariablesHelper.d.ts",
      "import": "./dist/src/VariablesHelper.mjs"
    },
    "./index": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.mjs"
    }
  },
  "type": "module",
  "scripts": {
    "lint": "eslint ./src",
    "typecheck": "tsc --noEmit",
    "build-assets:dev": "tsc && vite build --mode development --minify false && node ../sdk-shared/scripts/generate-exports.mjs",
    "build-assets:dev-watch": "tsc && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc && vite build && node ../sdk-shared/scripts/generate-exports.mjs"
  },
  "dependencies": {
    "@plitzi/sdk-shared": "workspace:*",
    "eslint": "^9.39.1",
    "lodash-es": "^4.17.21"
  },
  "devDependencies": {
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  }
}
