{
  "name": "@plitzi/sdk-event-bridge",
  "version": "0.27.17",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.mjs"
    },
    "./EventBridge": {
      "types": "./dist/src/EventBridge.d.ts",
      "import": "./dist/src/EventBridge.mjs"
    },
    "./EventBridgeContext": {
      "types": "./dist/src/EventBridgeContext.d.ts",
      "import": "./dist/src/EventBridgeContext.mjs"
    },
    "./EventBridgeContextProvider": {
      "types": "./dist/src/EventBridgeContextProvider.d.ts",
      "import": "./dist/src/EventBridgeContextProvider.mjs"
    },
    "./EventBridgeHelper": {
      "types": "./dist/src/EventBridgeHelper.d.ts",
      "import": "./dist/src/EventBridgeHelper.mjs"
    },
    "./hooks/useEventBridge": {
      "types": "./dist/src/hooks/useEventBridge.d.ts",
      "import": "./dist/src/hooks/useEventBridge.mjs"
    },
    "./index": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.mjs"
    }
  },
  "scripts": {
    "lint": "eslint ./src",
    "typecheck": "tsc --noEmit",
    "build-assets:dev": "tsc && vite build --mode development --minify false && node ../sdk-shared/scripts/generate-exports.mjs",
    "build-assets:dev-watch": "tsc && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc && vite build && node ../sdk-shared/scripts/generate-exports.mjs"
  },
  "type": "module",
  "dependencies": {
    "@plitzi/sdk-shared": "workspace:*",
    "lodash-es": "^4.17.23",
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
