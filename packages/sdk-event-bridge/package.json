{
  "name": "@plitzi/sdk-event-bridge",
  "version": "0.30.19",
  "license": "AGPL-3.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com/"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./EventBridge": {
      "types": "./dist/EventBridge.d.ts",
      "import": "./dist/EventBridge.mjs"
    },
    "./EventBridgeContext": {
      "types": "./dist/EventBridgeContext.d.ts",
      "import": "./dist/EventBridgeContext.mjs"
    },
    "./EventBridgeContextProvider": {
      "types": "./dist/EventBridgeContextProvider.d.ts",
      "import": "./dist/EventBridgeContextProvider.mjs"
    },
    "./EventBridgeHelper": {
      "types": "./dist/EventBridgeHelper.d.ts",
      "import": "./dist/EventBridgeHelper.mjs"
    },
    "./hooks/useEventBridge": {
      "types": "./dist/hooks/useEventBridge.d.ts",
      "import": "./dist/hooks/useEventBridge.mjs"
    },
    "./index": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "lint": "eslint ./src",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "build:dev": "vite build --mode development --minify false && node ../sdk-shared/scripts/generate-exports.mjs",
    "build:dev-watch": "vite build --mode development --watch --minify false",
    "build:prod": "vite build && node ../sdk-shared/scripts/generate-exports.mjs"
  },
  "type": "module",
  "sideEffects": false,
  "dependencies": {
    "@plitzi/sdk-shared": "workspace:*",
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
