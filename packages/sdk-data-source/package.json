{
  "name": "@plitzi/sdk-data-source",
  "version": "0.23.24",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es",
      "require": "./dist/index.cjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*",
      "require": "./dist/*"
    }
  },
  "scripts": {
    "lint": "eslint ./src",
    "build-assets:dev": "tsc -p ./tsconfig.app.json && vite build --mode development --minify false",
    "build-assets:dev-watch": "tsc -p ./tsconfig.app.json && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc -p ./tsconfig.app.json && vite build"
  },
  "type": "module",
  "devDependencies": {
    "eslint": "^9.27.0",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@plitzi/sdk-auth": "workspace:*",
    "@plitzi/sdk-event-bridge": "workspace:*",
    "@plitzi/sdk-navigation": "workspace:*",
    "@plitzi/sdk-schema": "workspace:*",
    "@plitzi/sdk-shared": "workspace:*",
    "@plitzi/sdk-state": "workspace:*",
    "lodash": "^4.17.21",
    "moment": "^2.30.1"
  }
}
