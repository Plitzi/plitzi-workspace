{
  "name": "@plitzi/sdk-data-source",
  "version": "0.30.17",
  "license": "AGPL-3.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com/"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./DataSourceContextProvider": {
      "types": "./dist/DataSourceContextProvider.d.ts",
      "import": "./dist/DataSourceContextProvider.mjs"
    },
    "./helpers/getBindingsDetails": {
      "types": "./dist/helpers/getBindingsDetails.d.ts",
      "import": "./dist/helpers/getBindingsDetails.mjs"
    },
    "./index": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./sources/AuthSource": {
      "types": "./dist/sources/AuthSource.d.ts",
      "import": "./dist/sources/AuthSource.mjs"
    },
    "./sources/NavigationSource": {
      "types": "./dist/sources/NavigationSource.d.ts",
      "import": "./dist/sources/NavigationSource.mjs"
    },
    "./sources/PageStateSource": {
      "types": "./dist/sources/PageStateSource.d.ts",
      "import": "./dist/sources/PageStateSource.mjs"
    },
    "./sources/VariablesSource": {
      "types": "./dist/sources/VariablesSource.d.ts",
      "import": "./dist/sources/VariablesSource.mjs"
    },
    "./utility": {
      "types": "./dist/utility/index.d.ts",
      "import": "./dist/utility/index.mjs"
    },
    "./utility/arrayMap": {
      "types": "./dist/utility/arrayMap.d.ts",
      "import": "./dist/utility/arrayMap.mjs"
    },
    "./utility/capitalize": {
      "types": "./dist/utility/capitalize.d.ts",
      "import": "./dist/utility/capitalize.mjs"
    },
    "./utility/dateConverter": {
      "types": "./dist/utility/dateConverter.d.ts",
      "import": "./dist/utility/dateConverter.mjs"
    },
    "./utility/index": {
      "types": "./dist/utility/index.d.ts",
      "import": "./dist/utility/index.mjs"
    },
    "./utility/staticValue": {
      "types": "./dist/utility/staticValue.d.ts",
      "import": "./dist/utility/staticValue.mjs"
    },
    "./utility/stringToArray": {
      "types": "./dist/utility/stringToArray.d.ts",
      "import": "./dist/utility/stringToArray.mjs"
    },
    "./utility/styleSelector": {
      "types": "./dist/utility/styleSelector.d.ts",
      "import": "./dist/utility/styleSelector.mjs"
    },
    "./utility/twigTemplate": {
      "types": "./dist/utility/twigTemplate.d.ts",
      "import": "./dist/utility/twigTemplate.mjs"
    }
  },
  "scripts": {
    "lint": "eslint ./src",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "build:dev": "vite build --mode development --minify false && node ../sdk-shared/scripts/generate-exports.mjs",
    "build:dev-watch": "vite build --mode development --watch --minify false",
    "build:prod": "vite build && node ../sdk-shared/scripts/generate-exports.mjs"
  },
  "type": "module",
  "sideEffects": false,
  "devDependencies": {
    "eslint": "^9.39.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@plitzi/sdk-auth": "workspace:*",
    "@plitzi/sdk-event-bridge": "workspace:*",
    "@plitzi/sdk-navigation": "workspace:*",
    "@plitzi/sdk-schema": "workspace:*",
    "@plitzi/sdk-shared": "workspace:*",
    "@plitzi/sdk-state": "workspace:*",
    "@plitzi/sdk-store": "workspace:*"
  }
}
