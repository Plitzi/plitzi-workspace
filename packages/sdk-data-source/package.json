{
  "name": "@plitzi/sdk-data-source",
  "version": "0.24.7",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/src/index.mjs",
      "types": "./dist/src/index.d.ts"
    },
    "./DataSourceContextProvider": {
      "import": "./dist/src/DataSourceContextProvider.mjs",
      "types": "./dist/src/DataSourceContextProvider.d.ts"
    },
    "./helpers/getBindingsDetails": {
      "import": "./dist/src/helpers/getBindingsDetails.mjs",
      "types": "./dist/src/helpers/getBindingsDetails.d.ts"
    },
    "./index": {
      "import": "./dist/src/index.mjs",
      "types": "./dist/src/index.d.ts"
    },
    "./sources/NavigationSource": {
      "import": "./dist/src/sources/NavigationSource.mjs",
      "types": "./dist/src/sources/NavigationSource.d.ts"
    },
    "./sources/PageStateSource": {
      "import": "./dist/src/sources/PageStateSource.mjs",
      "types": "./dist/src/sources/PageStateSource.d.ts"
    },
    "./sources/UserSource": {
      "import": "./dist/src/sources/UserSource.mjs",
      "types": "./dist/src/sources/UserSource.d.ts"
    },
    "./sources/VariablesSource": {
      "import": "./dist/src/sources/VariablesSource.mjs",
      "types": "./dist/src/sources/VariablesSource.d.ts"
    },
    "./utility": {
      "import": "./dist/src/utility/index.mjs",
      "types": "./dist/src/utility/index.d.ts"
    },
    "./utility/arrayMap": {
      "import": "./dist/src/utility/arrayMap.mjs",
      "types": "./dist/src/utility/arrayMap.d.ts"
    },
    "./utility/capitalize": {
      "import": "./dist/src/utility/capitalize.mjs",
      "types": "./dist/src/utility/capitalize.d.ts"
    },
    "./utility/dateConverter": {
      "import": "./dist/src/utility/dateConverter.mjs",
      "types": "./dist/src/utility/dateConverter.d.ts"
    },
    "./utility/index": {
      "import": "./dist/src/utility/index.mjs",
      "types": "./dist/src/utility/index.d.ts"
    },
    "./utility/staticValue": {
      "import": "./dist/src/utility/staticValue.mjs",
      "types": "./dist/src/utility/staticValue.d.ts"
    },
    "./utility/twigTemplate": {
      "import": "./dist/src/utility/twigTemplate.mjs",
      "types": "./dist/src/utility/twigTemplate.d.ts"
    }
  },
  "scripts": {
    "lint": "eslint ./src",
    "typecheck": "tsc --noEmit",
    "build-assets:dev": "tsc && vite build --mode development --minify false && node ../sdk-shared/scripts/generate-exports.mjs",
    "build-assets:dev-watch": "tsc && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc && vite build && node ../sdk-shared/scripts/generate-exports.mjs"
  },
  "type": "module",
  "devDependencies": {
    "eslint": "^9.36.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7"
  },
  "dependencies": {
    "@plitzi/sdk-auth": "workspace:*",
    "@plitzi/sdk-event-bridge": "workspace:*",
    "@plitzi/sdk-navigation": "workspace:*",
    "@plitzi/sdk-schema": "workspace:*",
    "@plitzi/sdk-shared": "workspace:*",
    "@plitzi/sdk-state": "workspace:*",
    "lodash": "^4.17.21",
    "moment": "^2.30.1"
  }
}
