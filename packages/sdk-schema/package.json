{
  "name": "@plitzi/sdk-schema",
  "version": "0.23.24",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es",
      "require": "./dist/index.cjs"
    },
    "./SchemaContext": {
      "types": "./dist/SchemaContext.d.ts",
      "import": "./dist/SchemaContext.es",
      "require": "./dist/SchemaContext.cjs"
    },
    "./SchemaSettingsContext": {
      "types": "./dist/SchemaSettingsContext.d.ts",
      "import": "./dist/SchemaSettingsContext.es",
      "require": "./dist/SchemaSettingsContext.cjs"
    },
    "./FlatMap": {
      "types": "./dist/helpers/FlatMap.d.ts",
      "import": "./dist/helpers/FlatMap.es",
      "require": "./dist/helpers/FlatMap.cjs"
    }
  },
  "type": "module",
  "scripts": {
    "lint": "eslint ./src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "build-assets:dev": "tsc -p ./tsconfig.app.json && vite build --mode development --minify false",
    "build-assets:dev-watch": "tsc -p ./tsconfig.app.json && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc -p ./tsconfig.app.json && vite build"
  },
  "dependencies": {
    "@plitzi/sdk-shared": "workspace:*",
    "@plitzi/sdk-style": "workspace:*",
    "lodash": "^4.17.21",
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "eslint": "^9.21.0",
    "vite": "^6.2.0",
    "vitest": "^3.0.7"
  }
}
