{
  "name": "@plitzi/sdk-schema",
  "version": "0.28.14",
  "license": "GPLv3",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.mjs"
    },
    "./SchemaMainContext": {
      "types": "./dist/src/SchemaMainContext.d.ts",
      "import": "./dist/src/SchemaMainContext.mjs"
    },
    "./SchemaReducer": {
      "types": "./dist/src/SchemaReducer.d.ts",
      "import": "./dist/src/SchemaReducer.mjs"
    },
    "./SchemaSettingsContext": {
      "types": "./dist/src/SchemaSettingsContext.d.ts",
      "import": "./dist/src/SchemaSettingsContext.mjs"
    },
    "./helpers/FlatMap": {
      "types": "./dist/src/helpers/FlatMap.d.ts",
      "import": "./dist/src/helpers/FlatMap.mjs"
    },
    "./index": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.mjs"
    }
  },
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "lint": "eslint ./src",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "build-assets:dev": "tsc -p tsconfig.app.json && vite build --mode development --minify false && node ../sdk-shared/scripts/generate-exports.mjs",
    "build-assets:dev-watch": "tsc -p tsconfig.app.json && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc -p tsconfig.app.json && vite build && node ../sdk-shared/scripts/generate-exports.mjs"
  },
  "dependencies": {
    "@plitzi/sdk-shared": "workspace:*",
    "@plitzi/sdk-style": "workspace:*",
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
