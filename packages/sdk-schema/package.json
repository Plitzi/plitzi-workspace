{
  "name": "@plitzi/sdk-schema",
  "version": "0.25.1",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.mjs"
    },
    "./SchemaContext": {
      "types": "./dist/src/SchemaContext.d.ts",
      "import": "./dist/src/SchemaContext.mjs"
    },
    "./SchemaMainContext": {
      "types": "./dist/src/SchemaMainContext.d.ts",
      "import": "./dist/src/SchemaMainContext.mjs"
    },
    "./SchemaSettingsContext": {
      "types": "./dist/src/SchemaSettingsContext.d.ts",
      "import": "./dist/src/SchemaSettingsContext.mjs"
    },
    "./helpers/FlatMap": {
      "types": "./dist/src/helpers/FlatMap.d.ts",
      "import": "./dist/src/helpers/FlatMap.mjs"
    },
    "./index": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.mjs"
    }
  },
  "type": "module",
  "scripts": {
    "lint": "eslint ./src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "build-assets:dev": "tsc && vite build --mode development --minify false && node ../sdk-shared/scripts/generate-exports.mjs",
    "build-assets:dev-watch": "tsc && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc && vite build && node ../sdk-shared/scripts/generate-exports.mjs"
  },
  "dependencies": {
    "@plitzi/sdk-shared": "workspace:*",
    "@plitzi/sdk-style": "workspace:*",
    "lodash": "^4.17.21",
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "eslint": "^9.38.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^4.0.2"
  }
}
