{
  "platform": {
    "desktop": {
      "heading-rdGM": {
        "name": "heading-rdGM",
        "type": "class",
        "attributes": {
          "base": {
            "default": {
              "color": "var(--fancyVariableColor)",
              "background-color": "var(--primaryColor)"
            }
          }
        },
        "cache": ".heading-rdGM{color:var(--fancyVariableColor);background-color:var(--primaryColor);}"
      },
      "button-rdGM": {
        "name": "button-rdGM",
        "type": "class",
        "attributes": {
          "base": {
            "default": {
              "color": "var(--fancyVariableColor)",
              "background-color": "var(--primaryColor)"
            }
          }
        },
        "cache": ".button-rdGM{color:var(--fancyVariableColor);background-color:var(--primaryColor);}"
      }
    },
    "tablet": {},
    "mobile": {}
  },
  "theme": {
    "default": "system",
    "schemes": ["light", "dark"]
  },
  "variables": {},
  "cache": ".heading-rdGM{color:var(--fancyVariableColor);background-color:var(--primaryColor);}.button-rdGM{color:var(--fancyVariableColor);background-color:var(--primaryColor);}"
}
