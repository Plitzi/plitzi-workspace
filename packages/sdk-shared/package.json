{
  "name": "@plitzi/sdk-shared",
  "version": "0.23.24",
  "files": [
    "dist",
    "eslint.config.mjs",
    "jest.config.js",
    "jest.setup.js",
    "tailwind.config.js",
    "vite.config.mjs",
    "setupTests.ts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es",
      "require": "./dist/index.cjs"
    },
    "./eslint.config.mjs": "./eslint.config.old.mjs",
    "./eslint.config.ts.mjs": "./eslint.config.mjs",
    "./jest.config": "./jest.config.js",
    "./jest.setup": "./jest.setup.js",
    "./babel.config": "./babel.config.mjs",
    "./tailwind.config": "./tailwind.config.js",
    "./tsconfig.json": "./tsconfig.json",
    "./tsconfig.app.json": "./tsconfig.app.json",
    "./vite.config.mjs": "./vite.config.mjs",
    "./setupTests.ts": "./setupTests.ts",
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*",
      "require": "./dist/*"
    }
  },
  "type": "module",
  "scripts": {
    "lint": "eslint ./src",
    "typecheck": "tsc --noEmit",
    "build-assets:dev": "tsc -p ./tsconfig.app.json && vite build --mode development --minify false",
    "build-assets:dev-watch": "tsc -p ./tsconfig.app.json && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc -p ./tsconfig.app.json && vite build"
  },
  "dependencies": {
    "@plitzi/plitzi-ui": "^0.2.0",
    "lodash": "^4.17.21",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "twig": "^1.17.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.27.2",
    "@babel/core": "^7.27.1",
    "@babel/eslint-parser": "^7.27.1",
    "@babel/plugin-syntax-flow": "^7.27.1",
    "@babel/plugin-transform-react-jsx": "^7.27.1",
    "@babel/preset-env": "^7.27.2",
    "@eslint/js": "^9.27.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@tailwindcss/forms": "^0.5.10",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.17",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@types/twig": "^1.12.16",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.1.4",
    "babel-minify": "^0.5.2",
    "eslint": "^9.27.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^10.1.5",
    "eslint-config-turbo": "^2.5.3",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-cypress": "^4.3.0",
    "eslint-plugin-flowtype": "8.0.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-jsdoc": "^50.6.17",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-storybook": "^0.12.0",
    "globals": "^16.1.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.7",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-react": "^4.0.1",
    "vitest": "^3.1.4",
    "vitest-fetch-mock": "^0.4.5"
  }
}
