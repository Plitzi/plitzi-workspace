{
  "name": "@plitzi/sdk-plugins",
  "version": "0.23.24",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es",
      "require": "./dist/index.cjs"
    },
    "./PluginsContext": {
      "types": "./dist/PluginsContext.d.ts",
      "import": "./dist/PluginsContext.es",
      "require": "./dist/PluginsContext.cjs"
    },
    "./PluginHelper": {
      "types": "./dist/PluginHelper.d.ts",
      "import": "./dist/PluginHelper.es",
      "require": "./dist/PluginHelper.cjs"
    }
  },
  "scripts": {
    "lint": "eslint ./src",
    "build-assets:dev": "tsc -p ./tsconfig.app.json && vite build --mode development --minify false",
    "build-assets:dev-watch": "tsc -p ./tsconfig.app.json && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc -p ./tsconfig.app.json && vite build"
