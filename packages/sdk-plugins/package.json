{
  "name": "@plitzi/sdk-plugins",
  "version": "0.24.4",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/src/index.mjs",
      "types": "./dist/src/index.d.ts"
    },
    "./PluginHelper": {
      "import": "./dist/src/PluginHelper.mjs",
      "types": "./dist/src/PluginHelper.d.ts"
    },
    "./PluginsContext": {
      "import": "./dist/src/PluginsContext.mjs",
      "types": "./dist/src/PluginsContext.d.ts"
    },
    "./index": {
      "import": "./dist/src/index.mjs",
      "types": "./dist/src/index.d.ts"
    }
  },
  "scripts": {
    "lint": "eslint ./src",
    "typecheck": "tsc --noEmit",
    "build-assets:dev": "tsc && vite build --mode development --minify false && node ../sdk-shared/scripts/generate-exports.mjs",
    "build-assets:dev-watch": "tsc && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc && vite build && node ../sdk-shared/scripts/generate-exports.mjs"
  },
  "type": "module",
  "dependencies": {
    "@plitzi/sdk-shared": "workspace:*",
    "lodash": "^4.17.21",
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "eslint": "^9.35.0",
    "vite": "^7.1.5"
  }
}