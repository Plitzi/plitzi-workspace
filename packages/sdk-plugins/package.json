{
  "name": "@plitzi/sdk-plugins",
  "version": "0.24.2",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es",
      "require": "./dist/index.cjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*",
      "require": "./dist/*"
    }
  },
  "scripts": {
    "lint": "eslint ./src",
    "typecheck": "tsc --noEmit",
    "build-assets:dev": "tsc && vite build --mode development --minify false",
    "build-assets:dev-watch": "tsc && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc && vite build"
  },
  "type": "module",
  "dependencies": {
    "@plitzi/sdk-shared": "workspace:*",
    "lodash": "^4.17.21",
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "eslint": "^9.35.0",
    "vite": "^7.1.4"
  }
}
