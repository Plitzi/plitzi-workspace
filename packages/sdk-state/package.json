{
  "name": "@plitzi/sdk-state",
  "version": "0.30.16",
  "license": "AGPL-3.0",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.mjs"
    },
    "./StateManagerContext": {
      "types": "./dist/src/StateManagerContext.d.ts",
      "import": "./dist/src/StateManagerContext.mjs"
    },
    "./StateManagerContextProvider": {
      "types": "./dist/src/StateManagerContextProvider.d.ts",
      "import": "./dist/src/StateManagerContextProvider.mjs"
    },
    "./index": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.mjs"
    }
  },
  "scripts": {
    "lint": "eslint ./src",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "build:dev": "tsc -p tsconfig.app.json && vite build --mode development --minify false && node ../sdk-shared/scripts/generate-exports.mjs",
    "build:dev-watch": "tsc -p tsconfig.app.json && vite build --mode development --watch --minify false",
    "build:prod": "tsc -p tsconfig.app.json && vite build && node ../sdk-shared/scripts/generate-exports.mjs"
  },
  "type": "module",
  "sideEffects": false,
  "dependencies": {
    "@plitzi/sdk-schema": "workspace:*",
    "@plitzi/sdk-shared": "workspace:*",
    "immer": "^11.1.4"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
