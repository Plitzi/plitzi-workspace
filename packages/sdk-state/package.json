{
  "name": "@plitzi/sdk-state",
  "version": "0.27.1",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.mjs"
    },
    "./StateManagerContext": {
      "types": "./dist/src/StateManagerContext.d.ts",
      "import": "./dist/src/StateManagerContext.mjs"
    },
    "./StateManagerContextProvider": {
      "types": "./dist/src/StateManagerContextProvider.d.ts",
      "import": "./dist/src/StateManagerContextProvider.mjs"
    },
    "./index": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.mjs"
    }
  },
  "scripts": {
    "lint": "eslint ./src",
    "typecheck": "tsc --noEmit",
    "build-assets:dev": "tsc && vite build --mode development --minify false && node ../sdk-shared/scripts/generate-exports.mjs",
    "build-assets:dev-watch": "tsc && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc && vite build && node ../sdk-shared/scripts/generate-exports.mjs"
  },
  "type": "module",
  "dependencies": {
    "@plitzi/sdk-schema": "workspace:*",
    "@plitzi/sdk-shared": "workspace:*",
    "immer": "^11.0.1",
    "lodash-es": "^4.17.21"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  }
}
