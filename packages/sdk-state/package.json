{
  "name": "@plitzi/sdk-state",
  "version": "0.23.24",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es",
      "require": "./dist/index.cjs"
    },
    "./StateManagerContext": {
      "types": "./dist/StateManagerContext.d.ts",
      "import": "./dist/StateManagerContext.es",
      "require": "./dist/StateManagerContext.cjs"
    },
    "./StateManagerContextProvider": {
      "types": "./dist/StateManagerContextProvider.d.ts",
      "import": "./dist/StateManagerContextProvider.es",
      "require": "./dist/StateManagerContextProvider.cjs"
    }
  },
  "scripts": {
    "lint": "eslint ./src",
    "build-assets:dev": "tsc -p ./tsconfig.app.json && vite build --mode development --minify false",
    "build-assets:dev-watch": "tsc -p ./tsconfig.app.json && vite build --mode development --watch --minify false",
    "build-assets:prod": "tsc -p ./tsconfig.app.json && vite build"
  },
  "type": "module",
  "dependencies": {
    "@plitzi/sdk-schema": "workspace:*",
    "@plitzi/sdk-shared": "workspace:*",
    "immer": "^10.1.1",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "eslint": "^9.19.0",
    "vite": "^6.1.0"
  }
}
