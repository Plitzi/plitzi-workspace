{
  "name": "plitzi-store-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:published": "tsc --noEmit -p tsconfig.publish.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "bench": "vite-node src/components/Benchmark/bench/cli.ts",
