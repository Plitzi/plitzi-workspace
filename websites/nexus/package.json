    "bench:react": "vite-node src/components/Benchmark/bench/reactCli.ts"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "@stackblitz/sdk": "^1.11.0",
    "jotai": "^2.20.0",
    "mobx": "^6.16.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "valtio": "^2.3.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vite-node": "^6.0.0"
  }
